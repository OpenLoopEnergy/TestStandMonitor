# ── Local development ───────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./dev.db
MOCK_MODE=true
SIM_INTERVAL=0.5
FLASK_PORT=8000
EXPORT_DIR=./exports

# ── Production (Railway) ─────────────────────────────────────────────────────
# DATABASE_URL=postgresql://user:password@host:5432/dbname
# MOCK_MODE=false
# EXPORT_DIR=/app/exports

# CORS — comma-separated list of allowed frontend origins
# ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:5173

# Optional admin features
# ADMIN_REBOOT_KEY=your-secret-key-here
# ADMIN_REBOOT_ALLOWED_SUBNETS=127.0.0.1,192.168.1.0/24

# ── Raspberry Pi ─────────────────────────────────────────────────────────────
# BACKEND_WS_URL=wss://your-app.railway.app/ws/pi
# CAN_CHANNEL=can0
